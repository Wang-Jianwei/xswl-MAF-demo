# Provider: openai | azure | ollama
MAF_PROVIDER=openai

# OpenAI path
OPENAI_API_KEY=
MAF_MODEL_ID=gpt-4.1-mini

# 可选：自定义 OpenAI 兼容 API endpoint（vLLM、本地部署等）
# 例如：http://10.11.13.4:8721/v1
OPENAI_API_BASE=

# Azure path (when MAF_PROVIDER=azure)
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Ollama path (when MAF_PROVIDER=ollama)
# Endpoint format: http://localhost:11434 (default)
# Model ID: mistral, llama2, neural-chat, etc.
OLLAMA_ENDPOINT=http://localhost:11434

# 可选：为不同 Agent 指定不同模型（留空则使用 MAF_MODEL_ID）
# OpenAI 示例：
# MAF_MODEL_PRODUCT_MANAGER=gpt-4o-mini
# MAF_MODEL_ARCHITECT=gpt-4
# MAF_MODEL_DEVELOPER=gpt-4
# MAF_MODEL_REVIEWER=gpt-4
#
# Ollama 示例（成本优化）：
# MAF_MODEL_PRODUCT_MANAGER=mistral
# MAF_MODEL_ARCHITECT=neural-chat
# MAF_MODEL_DEVELOPER=neural-chat
# MAF_MODEL_REVIEWER=llama2
MAF_MODEL_PRODUCT_MANAGER=
MAF_MODEL_ARCHITECT=
MAF_MODEL_DEVELOPER=
MAF_MODEL_REVIEWER=

# Workflow mode: sequential | concurrent
MAF_WORKFLOW_MODE=sequential

# Optional: enable safe tool calling for developer/reviewer agents
# true|false (default false)
MAF_ENABLE_TOOLS=false
# Workspace root for file read/write and command execution
MAF_WORKSPACE_ROOT=.
# Command whitelist (comma-separated)
MAF_ALLOWED_COMMANDS=python,pytest,pip
# Command timeout in seconds
MAF_COMMAND_TIMEOUT_SECONDS=120
