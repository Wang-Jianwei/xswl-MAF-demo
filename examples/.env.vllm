# vLLM 本地模型配置示例
# 复制此文件为 .env 后使用

# 使用 OpenAI 兼容 API（vLLM）
MAF_PROVIDER=openai

# 本地服务不需要真实 API Key，可以是任意值
OPENAI_API_KEY=sk-local

# vLLM API endpoint
# 示例：Qwen3.5-27B 服务地址
OPENAI_API_BASE=http://10.11.13.4:8721/v1

# 模型名称（对应 vLLM 中的模型）
MAF_MODEL_ID=Qwen3.5-27B

# 为不同 Agent 分配不同的模型以优化成本和性能
# 产品经理：轻量级模型用于快速需求拆解
MAF_MODEL_PRODUCT_MANAGER=Qwen3.5-27B

# 架构师：强力模型用于复杂设计（可指向另一个 vLLM 实例）
# OPENAI_API_BASE_ARCHITECT=http://10.11.13.4:8720/v1
MAF_MODEL_ARCHITECT=Qwen3.5-35B

# 开发工程师：强力模型用于实现计划
MAF_MODEL_DEVELOPER=Qwen3.5-35B

# 评审员：强力模型用于严格评审
MAF_MODEL_REVIEWER=Qwen3.5-35B

# 工作流模式：sequential（默认，逐步执行）或 concurrent（并行执行架构和实现）
MAF_WORKFLOW_MODE=sequential
